# 服务端口
PORT=3000
HOST=0.0.0.0

# 数据库路径（Docker 内路径）
DATABASE_PATH=/app/data/caiwu.db

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=please-change-this-secret

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# DeepSeek AI 配置（文字 / 语音转写文本解析）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 阿里云百炼（DashScope）图片识别配置（qwen3-vl-flash 解析消费小票/截图）
# 也可在管理后台「系统设置 → 图片识别」里填，设置项 vision.* 会覆盖这里
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VL_MODEL=qwen3-vl-flash

# OpenILink Hub 配置（微信机器人）
HUB_URL=
BASE_URL=
